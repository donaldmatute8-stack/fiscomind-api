# Facturama PAC Configuration
# Add these to Railway Environment Variables

# Get API credentials from: https://apisandbox.facturama.mx/Docs
# Or production: https://api.facturama.mx

# Sandbox mode (for testing)
FACTURAMA_SANDBOX=true

# API Credentials (replace with your actual credentials)
FACTURAMA_API_KEY=your_api_key_here
FACTURAMA_API_SECRET=your_api_secret_here

# To get credentials:
# 1. Create account at https://facturama.mx
# 2. Go to API section
# 3. Generate API Key
# 4. Copy API Key and Secret
